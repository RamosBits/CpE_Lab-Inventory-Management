<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="900.0" prefWidth="1200.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cpe_lab_inventory.TransactionsController">
    <top>
        <HBox prefHeight="60.0" prefWidth="200.0" spacing="15.0" style="-fx-background-color: #c41c3b; -fx-padding: 10;" BorderPane.alignment="CENTER">
            <Button mnemonicParsing="false" onAction="#handleBackToMenu" style="-fx-padding: 8 15; -fx-font-size: 12; -fx-background-color: white; -fx-text-fill: #c41c3b; -fx-font-weight: bold;" text="← Back to Menu" />
            <Label fx:id="userLabel" prefHeight="40.0" prefWidth="1000.0" text="Transactions" textFill="white" alignment="CENTER_LEFT">
                <Font name="System Bold" size="24.0" />
            </Label>
            <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-padding: 8 15; -fx-font-size: 12; -fx-background-color: white; -fx-text-fill: #c41c3b; -fx-font-weight: bold;" text="Logout" />
        </HBox>
    </top>
    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" style="-fx-padding: 15;" BorderPane.alignment="CENTER">
            <Label text="Process Transactions (Borrow/Return)" textFill="#333333">
                <Font name="System Bold" size="16.0" />
            </Label>
            <VBox spacing="8.0" style="-fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-padding: 10;">
                <Label text="New Transaction" textFill="#666666">
                    <Font name="System Bold" size="12.0" />
                </Label>
                <HBox spacing="10.0">
                    <ComboBox fx:id="studentCombo" prefWidth="150.0" promptText="Select Student" />
                    <ComboBox fx:id="itemCombo" prefWidth="150.0" promptText="Select Item" />
                    <TextField fx:id="quantityField" prefWidth="80.0" promptText="Quantity" />
                    <TextField fx:id="orNumField" prefWidth="80.0" promptText="OR Number" />
                    <Button mnemonicParsing="false" onAction="#handleBorrow" style="-fx-padding: 8 15; -fx-background-color: #c41c3b; -fx-text-fill: white;" text="✓ Borrow" />
                    <Button mnemonicParsing="false" onAction="#handleReturn" style="-fx-padding: 8 15; -fx-background-color: #d32f2f; -fx-text-fill: white;" text="↩ Return" />
                </HBox>
            </VBox>
            <Label text="Transaction History" textFill="#333333">
                <Font name="System Bold" size="16.0" />
            </Label>
            <TableView fx:id="transactionsTable" prefHeight="550.0">
                <columns>
                    <TableColumn fx:id="transIdColumn" minWidth="80.0" prefWidth="80.0" text="Trans ID" />
                    <TableColumn fx:id="studentColumn" minWidth="100.0" prefWidth="100.0" text="Student" />
                    <TableColumn fx:id="itemColumn" minWidth="120.0" prefWidth="120.0" text="Item" />
                    <TableColumn fx:id="statusColumn" minWidth="80.0" prefWidth="80.0" text="Status" />
                    <TableColumn fx:id="dateColumn" minWidth="150.0" prefWidth="150.0" text="Date" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
