<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="900.0" prefWidth="1200.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cpe_lab_inventory.ItemsController">
    <top>
        <HBox prefHeight="60.0" prefWidth="200.0" spacing="15.0" style="-fx-background-color: #c41c3b; -fx-padding: 10;" BorderPane.alignment="CENTER">
            <Button mnemonicParsing="false" onAction="#handleBackToMenu" style="-fx-padding: 8 15; -fx-font-size: 12; -fx-background-color: white; -fx-text-fill: #c41c3b; -fx-font-weight: bold;" text="← Back to Menu" />
            <Label fx:id="userLabel" prefHeight="40.0" prefWidth="1000.0" text="Inventory Items" textFill="white" alignment="CENTER_LEFT">
                <Font name="System Bold" size="24.0" />
            </Label>
            <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-padding: 8 15; -fx-font-size: 12; -fx-background-color: white; -fx-text-fill: #c41c3b; -fx-font-weight: bold;" text="Logout" />
        </HBox>
    </top>
    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" style="-fx-padding: 15;" BorderPane.alignment="CENTER">
            <Label text="Manage Items" textFill="#333333">
                <Font name="System Bold" size="16.0" />
            </Label>
            <VBox spacing="8.0" style="-fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-padding: 10;">
                <Label text="Add New Item" textFill="#666666">
                    <Font name="System Bold" size="12.0" />
                </Label>
                <HBox spacing="10.0">
                    <TextField fx:id="itemNameField" prefWidth="150.0" promptText="Item Name" />
                    <ComboBox fx:id="itemTypeCombo" prefWidth="100.0" promptText="Type" />
                    <TextField fx:id="itemStockField" prefWidth="80.0" promptText="Stock" />
                    <Button mnemonicParsing="false" onAction="#handleAddItem" style="-fx-padding: 8 15; -fx-background-color: #c41c3b; -fx-text-fill: white;" text="Add Item" />
                </HBox>
            </VBox>
            <Label text="Inventory Items" textFill="#333333">
                <Font name="System Bold" size="16.0" />
            </Label>
            <TableView fx:id="itemsTable" prefHeight="550.0">
                <columns>
                    <TableColumn fx:id="itemIdColumn" minWidth="60.0" prefWidth="60.0" text="Item ID" />
                    <TableColumn fx:id="itemNameColumn" minWidth="150.0" prefWidth="150.0" text="Item Name" />
                    <TableColumn fx:id="itemTypeColumn" minWidth="100.0" prefWidth="100.0" text="Type" />
                    <TableColumn fx:id="totalStockColumn" minWidth="80.0" prefWidth="80.0" text="Total Stock" />
                    <TableColumn fx:id="currentStockColumn" minWidth="100.0" prefWidth="100.0" text="Current Stock" />
                </columns>
            </TableView>
            <HBox spacing="10.0">
                <Button mnemonicParsing="false" onAction="#handleEditItem" style="-fx-padding: 8 15; -fx-background-color: #1976d2; -fx-text-fill: white;" text="✎ Edit" />
                <Button mnemonicParsing="false" onAction="#handleDeleteItem" style="-fx-padding: 8 15; -fx-background-color: #d32f2f; -fx-text-fill: white;" text="✕ Delete" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
