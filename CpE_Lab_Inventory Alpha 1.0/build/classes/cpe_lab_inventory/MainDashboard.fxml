<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cpe_lab_inventory.MainDashboardController">
    <top>
        <HBox prefHeight="60.0" prefWidth="1100.0" spacing="20.0" style="-fx-background-color: #c41c3b; -fx-padding: 15;" BorderPane.alignment="CENTER">
            <Label fx:id="titleLabel" text="Admin Control Panel - Lab Inventory" textFill="WHITE">
                <Font name="System Bold" size="18.0" />
            </Label>
            <Label fx:id="userLabel" text="User" textFill="WHITE" HBox.hgrow="ALWAYS">
                <Font size="12.0" />
            </Label>
            <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-padding: 7 15; -fx-font-size: 11;" text="Logout" />
        </HBox>
    </top>
    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" spacing="30.0" style="-fx-padding: 40;" alignment="CENTER" BorderPane.alignment="CENTER">
            <Label text="Dashboard Menu" textFill="#333333" alignment="CENTER">
                <Font name="System Bold" size="24.0" />
            </Label>
            <HBox spacing="30.0" alignment="CENTER">
                <!-- Items Box -->
                <VBox prefHeight="280.0" prefWidth="280.0" spacing="15.0" style="-fx-border-color: #c41c3b; -fx-border-width: 3; -fx-padding: 20; -fx-background-color: #f9f9f9;" alignment="CENTER">
                    <Label text="📦" alignment="CENTER">
                        <Font size="60.0" />
                    </Label>
                    <Label text="Inventory Items" alignment="CENTER" textFill="#333333">
                        <Font name="System Bold" size="16.0" />
                    </Label>
                    <Label text="Manage items, add stock, view inventory" alignment="CENTER" textFill="#666666" wrapText="true">
                        <Font size="11.0" />
                    </Label>
                    <Button mnemonicParsing="false" onAction="#handleOpenItems" style="-fx-padding: 10 30; -fx-font-size: 12; -fx-background-color: #c41c3b; -fx-text-fill: white; -fx-cursor: hand;" text="Open" />
                </VBox>
                
                <!-- Transactions Box -->
                <VBox prefHeight="280.0" prefWidth="280.0" spacing="15.0" style="-fx-border-color: #c41c3b; -fx-border-width: 3; -fx-padding: 20; -fx-background-color: #f9f9f9;" alignment="CENTER">
                    <Label text="📋" alignment="CENTER">
                        <Font size="60.0" />
                    </Label>
                    <Label text="Transactions" alignment="CENTER" textFill="#333333">
                        <Font name="System Bold" size="16.0" />
                    </Label>
                    <Label text="Borrow and return equipment, track status" alignment="CENTER" textFill="#666666" wrapText="true">
                        <Font size="11.0" />
                    </Label>
                    <Button mnemonicParsing="false" onAction="#handleOpenTransactions" style="-fx-padding: 10 30; -fx-font-size: 12; -fx-background-color: #c41c3b; -fx-text-fill: white; -fx-cursor: hand;" text="Open" />
                </VBox>
                
                <!-- Students Box -->
                <VBox prefHeight="280.0" prefWidth="280.0" spacing="15.0" style="-fx-border-color: #c41c3b; -fx-border-width: 3; -fx-padding: 20; -fx-background-color: #f9f9f9;" alignment="CENTER">
                    <Label text="🎓" alignment="CENTER">
                        <Font size="60.0" />
                    </Label>
                    <Label text="Students" alignment="CENTER" textFill="#333333">
                        <Font name="System Bold" size="16.0" />
                    </Label>
                    <Label text="Register students, view enrollment info" alignment="CENTER" textFill="#666666" wrapText="true">
                        <Font size="11.0" />
                    </Label>
                    <Button mnemonicParsing="false" onAction="#handleOpenStudents" style="-fx-padding: 10 30; -fx-font-size: 12; -fx-background-color: #c41c3b; -fx-text-fill: white; -fx-cursor: hand;" text="Open" />
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
